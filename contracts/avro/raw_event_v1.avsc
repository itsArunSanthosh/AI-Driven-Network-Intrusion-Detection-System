{
  "type": "record",
  "name": "RawEvent",
  "namespace": "ai.nids",
  "fields": [
    {"name": "timestamp", "type": "long"},
    {"name": "src_ip", "type": "string"},
    {"name": "dst_ip", "type": "string"},
    {"name": "src_port", "type": "int"},
    {"name": "dst_port", "type": "int"},
    {"name": "protocol", "type": "string"},
    {"name": "packet_size", "type": "int"},
    {"name": "tcp_flags", "type": "string"}
  ]
}